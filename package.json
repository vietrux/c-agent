{
  "name": "c-agent",
  "version": "0.1.0",
  "description": "c-agent — terminal coding/offensive-security agent",
  "type": "module",
  "bin": {
    "cagent": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "test": "npm run build && npm run test:scheduler && npm run test:file-safety && npm run test:web-fetch && npm run test:tool-search && npm run test:bash-classifier && npm run test:result-cap && npm run test:secure-fs && npm run test:grep && npm run test:tools",
    "test:scheduler": "tsx scheduler-test.mts",
    "test:file-safety": "tsx file-safety-test.mts",
    "test:web-fetch": "tsx web-fetch-test.mts",
    "test:tool-search": "tsx tool-search-test.mts",
    "test:bash-classifier": "tsx bash-classifier-test.mts",
    "test:result-cap": "tsx result-cap-test.mts",
    "test:secure-fs": "tsx secure-fs-test.mts",
    "test:grep": "tsx grep-test.mts",
    "test:tools": "tsx tools-test.mts",
    "build": "tsc",
    "postbuild": "node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "build:bin": "node scripts/build-bin.mjs",
    "build:pkg": "node scripts/build-pkg.mjs",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "prepublishOnly": "rm -rf dist && tsc"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@earendil-works/pi-tui": "^0.78.0",
    "chalk": "^5.6.2",
    "crypto-js": "^4.2.0",
    "openai": "^6.41.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.19.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
